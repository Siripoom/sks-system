{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/guardians/layout,_N_T_/guardians/page,_N_T_/guardians"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/guardians/__PAGE__",
    "/guardians",
    "/_index",
    "/_head"
  ]
}